# ─────────────────────────────────────────────
# Environment Variables — copy this to .env and fill in your values
# ─────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env

# ── AviationStack API
# Get your free key at: https://aviationstack.com
# Free tier = 100 calls/month
# When you have the key, replace YOUR_KEY_HERE below
AVIATIONSTACK_API_KEY=YOUR_KEY_HERE

# ── Booking Agent HTTP Server
# This is the address where your Booking Agent HTTP server runs locally
# You don't need to change this unless port 8001 is taken on your machine
BOOKING_AGENT_URL=http://localhost:8001

# ── Notification Agent Webhook
# This is the address where your Notification Agent listens for webhooks
# Port 8002 is where it will receive incoming events (price drops, delays)
NOTIFICATION_AGENT_URL=http://localhost:8002

# ── Webhook Security
# Secret key shared with external services to verify webhook requests
# CHANGE THIS in production — never use the default!
WEBHOOK_SECRET=changeit