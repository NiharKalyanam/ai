{
  "name": "mcp-db-server",
  "version": "2.0.0",
  "description": "Pluggable MCP DB Server — Claude Desktop, HTTP API, Slack, Custom UI",
  "type": "module",
  "scripts": {
    "mcp":    "node src/index.js",
    "http":   "node src/http-server.js",
    "slack":  "node src/slack-bot.js",
    "ui":     "npx serve ui -p 5173",
    "all":    "node src/http-server.js & node src/slack-bot.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk":     "^0.24.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@slack/bolt":           "^3.19.0",
    "cors":                  "^2.8.5",
    "dotenv":                "^16.4.5",
    "express":               "^4.19.2",
    "mysql2":                "^3.9.7",
    "pg":                    "^8.11.5",
    "zod":                   "^3.23.8"
  }
}