# SERVER
MCP_SERVER_NAME=mcp-db-server
# DATABASE 
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=identityiq
DB_USER=root
DB_PASSWORD=password
DB_TABLE_PREFIX=spt_

# AI MODEL 
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=sk-ant-api03-******

# MCP TOOLS 
MCP_TOOLS=query_database,describe_schema,sample_data,search_records

# HTTP SERVER 
# Start with: node src/http-server.js
HTTP_PORT=3344

# THE ONE TOKEN TO CHANGE WHEN SHARING CODE:
# Anyone who runs your code sets this to their own secret value.
# All API calls require: Authorization: Bearer <API_TOKEN>
API_TOKEN=change-me-before-sharing

# SCHEMA DISCOVERY
SCHEMA_AUTO_DISCOVER=true
SCHEMA_MAX_TABLES=50
SCHEMA_ENUM_COLUMNS=status,state,type,phase,action,op,operation,source,level,completion_status,result,severity,outcome
SCHEMA_SKIP_COLUMNS=attributes,xml,extended_attributes,scorecard,preferences,arguments,config

# SAFETY 
MAX_ROWS=500
